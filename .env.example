# Copy this file to ".env" and fill in your keys. 
# See README section 1 for a step-by-step guide to obtaining each free key.

# Required
GROQ_API_KEY=your_groq_api_key_here
PIXABAY_API_KEY=your_pixabay_api_key_here

# Recommended (extra free sources for higher volume)
PEXELS_API_KEY=your_pexels_api_key_here
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Optional: an Openverse token raises its per-search limit from 20 to 50 and
# improves reliability. Register a free token (see README) and paste the values.
OPENVERSE_CLIENT_ID=
OPENVERSE_CLIENT_SECRET=
